<Page x:Class="LeapMergeDoc.Pages.FilesCollectionImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="700"
      Title="Files Collection Import"
      Background="#F5F5F5">
    
    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="FileSelectButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Files Collection Import" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#1F2937"/>
            <TextBlock Text="Upload files from local folders to S3 and import to database" 
                       FontSize="14" Foreground="#6B7280" Margin="0,8,0,0"/>
        </StackPanel>
        
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Database Connection" FontWeight="SemiBold" FontSize="15" Foreground="#374151" Margin="0,0,0,10"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtConnectionString" Grid.Column="0" 
                             Text="Server=localhost;Database=customerdbv1;User=root;Password=1qaz!QAZ"
                             FontSize="12" Padding="10" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>
                    <Button Grid.Column="1" Content="🔗 Test" Margin="10,0,0,0"
                            Style="{StaticResource FileSelectButton}"
                            Click="BtnTestConnection_Click"/>
                </Grid>
            </Grid>
        </Border>
        
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="S3 Configuration" FontWeight="SemiBold" FontSize="15" Foreground="#374151" Margin="0,0,0,5"/>
                <TextBlock Grid.Row="0" Text="(Using AWS Profile configured on your system)" 
                           FontSize="11" Foreground="#6B7280" Margin="0,20,0,10" FontStyle="Italic"/>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Bucket Name:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#374151"/>
                        <TextBox x:Name="txtBucketName" Grid.Column="1" 
                                 FontSize="12" Padding="10" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"
                                 TextChanged="txtBucketName_TextChanged"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Profile Path:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#374151"/>
                        <TextBox x:Name="txtProfilePath" Grid.Column="1" 
                                 Text="C:\AWS_Profile\LAITLegal.txt"
                                 FontSize="12" Padding="10" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Case ID:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#374151" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCaseId" Grid.Column="1" 
                         FontSize="12" Padding="10" VerticalContentAlignment="Center"
                         BorderBrush="#D1D5DB" BorderThickness="1"
                         TextChanged="txtCaseId_TextChanged"/>
                <Button Grid.Column="2" Content="🔍 Verify" Margin="10,0,0,0"
                        Style="{StaticResource FileSelectButton}"
                        Click="BtnVerifyCase_Click"/>
            </Grid>
        </Border>
        
        <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Source Folder" FontWeight="SemiBold" FontSize="15" Foreground="#374151"/>
                    <TextBlock x:Name="txtFolderPath" Text="No folder selected" 
                               FontSize="12" Foreground="#9CA3AF" Margin="0,5,0,0" 
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="1" Content="📁 Browse..." 
                        Style="{StaticResource FileSelectButton}"
                        Click="BtnSelectFolder_Click"/>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="btnUpload" Content="☁️ Upload Files" 
                    Style="{StaticResource SuccessButton}"
                    IsEnabled="False"
                    Margin="0,0,10,0"
                    Click="BtnUpload_Click"/>
            <Button x:Name="btnTruncate" Content="🗑️ Truncate Uploaded Files" 
                    Style="{StaticResource DangerButton}"
                    Click="BtnTruncate_Click"/>
        </StackPanel>
        
        <!-- Status Area -->
        <Border Grid.Row="6" Background="White" CornerRadius="12" Padding="20" MinHeight="400">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Status &amp; Logs" FontWeight="SemiBold" FontSize="15" Foreground="#374151" Margin="0,0,0,10"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBox x:Name="txtStatus" Text="Ready. Configure S3, select case, and choose source folder to begin." 
                             FontSize="13" Foreground="#6B7280" 
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"/>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>
    </ScrollViewer>
</Page>
