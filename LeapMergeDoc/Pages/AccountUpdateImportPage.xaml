<Page x:Class="LeapMergeDoc.Pages.AccountUpdateImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="Account Update Import"
      Background="#F5F5F5">
    
    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="FileSelectButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Account Update Import" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#1F2937"/>
            <TextBlock Text="Import Bank Receipts, Bank Payments, and Client to Office transfers from Excel" 
                       FontSize="14" Foreground="#6B7280" Margin="0,8,0,0"/>
        </StackPanel>
        
        <!-- Database Connection -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                           Text="Database Connection" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#374151" Margin="0,0,0,12"/>
                
                <TextBox x:Name="txtConnectionString" Grid.Row="1" Grid.Column="0"
                         Text="Server=localhost;Database=bais-live;User=root;Password=1qaz!QAZ"
                         FontSize="13" Padding="12,10"
                         BorderBrush="#D1D5DB" BorderThickness="1"
                         Margin="0,0,12,0"/>
                
                <Button x:Name="btnTestConnection" Grid.Row="1" Grid.Column="1"
                        Content="Test Connection"
                        Style="{StaticResource FileSelectButton}"
                        Click="BtnTestConnection_Click"/>
            </Grid>
        </Border>

        <!-- Bank Account Selection -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" 
                           Text="Default Bank Accounts" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#374151" Margin="0,0,0,12"/>
                
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Client Bank Account:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbClientBank" 
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="BankId"
                              FontSize="13" Padding="10,8"
                              BorderBrush="#D1D5DB" BorderThickness="1"/>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Office Bank Account:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbOfficeBank"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="BankId"
                              FontSize="13" Padding="10,8"
                              BorderBrush="#D1D5DB" BorderThickness="1"/>
                </StackPanel>
                
                <Button x:Name="btnLoadBanks" Grid.Row="1" Grid.Column="2"
                        Content="Load Banks"
                        Style="{StaticResource FileSelectButton}"
                        Click="BtnLoadBanks_Click"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
        
        <!-- File Selection -->
        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                           Text="Excel File Selection" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="#374151" Margin="0,0,0,12"/>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="btnSelectFile" 
                            Content="📁 Select Excel File"
                            Style="{StaticResource FileSelectButton}"
                            Click="BtnSelectFile_Click"/>
                    <TextBlock x:Name="txtFilePath" 
                               Text="No file selected" 
                               FontSize="13" Foreground="#9CA3AF"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <!-- Expected Format Info -->
                <Border Grid.Row="2" Background="#F0FDF4" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Expected Excel Format (Bank Account Register):" FontWeight="SemiBold" Foreground="#166534" Margin="0,0,0,4"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12">
                            <Run FontWeight="SemiBold">Required Columns:</Run>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column B: Transaction Date (dd/MM/yyyy)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column E: Reason (Receipt/Payment)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column J: Withdrawal (Payment amount)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column K: Deposit Balance (Receipt amount)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column O: Receipts/Payment type
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column P: Client to Office indicator
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="8,2,0,0">
                            • Column Q: Case Number (case_reference_auto)
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="#166534" FontSize="12" Margin="0,6,0,0">
                            <Run FontWeight="SemiBold">Note:</Run> Headers expected in Row 2, data starts from Row 3
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Action Buttons and Status -->
        <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="20" MinHeight="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="280"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,16">
                    <Button x:Name="btnPreview" 
                            Content="👁️ Preview Data"
                            Style="{StaticResource ModernButton}"
                            Click="BtnPreview_Click"
                            IsEnabled="False"/>
                    <Button x:Name="btnImport" 
                            Content="⬆️ Import Transactions"
                            Style="{StaticResource SuccessButton}"
                            Click="BtnImport_Click"
                            IsEnabled="False"
                            Margin="12,0,0,0"/>
                    <Button x:Name="btnClearLog" 
                            Content="🗑️ Clear Log"
                            Style="{StaticResource FileSelectButton}"
                            Click="BtnClearLog_Click"
                            Margin="12,0,0,0"/>
                </StackPanel>
                
                <Border Grid.Row="1" Background="#1E293B" CornerRadius="8" Padding="12">
                    <ScrollViewer x:Name="logScrollViewer" 
                                  VerticalScrollBarVisibility="Visible" 
                                  HorizontalScrollBarVisibility="Auto"
                                  Height="250">
                        <TextBox x:Name="txtStatus" 
                                 Text="Ready. Select an Excel file to begin..."
                                 FontFamily="Consolas" FontSize="13"
                                 Foreground="#10B981"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Page>
