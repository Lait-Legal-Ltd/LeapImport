<Page x:Class="LeapMergeDoc.Pages.SharePointImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="SharePoint Import"
      Background="#F5F5F5">
    
    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D97706"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <!-- Header -->
            <TextBlock Text="SharePoint Import" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#1F2937"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Download files from SharePoint and import to database" 
                       FontSize="14" 
                       Foreground="#6B7280"
                       Margin="0,0,0,24"/>

            <!-- Authentication Section -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🔐 Step 1: Azure AD Authentication" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                    <TextBlock Text="Enter your Azure AD App Registration credentials (Client Credentials Flow - no browser required)" 
                               FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tenant ID (Directory ID):" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTenantId" 
                                     Height="36"
                                     Padding="10,8"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Client ID (Application ID):" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtClientId" 
                                     Height="36"
                                     Padding="10,8"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Client Secret (optional):" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="txtClientSecret" 
                                     Height="36"
                                     Padding="10,8"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1">
                                <PasswordBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </PasswordBox.Resources>
                            </PasswordBox>
                        </StackPanel>
                    </Grid>
                    
                    <Border Background="#FEF3C7" CornerRadius="6" Padding="12" Margin="0,12,0,12">
                        <StackPanel>
                            <TextBlock FontSize="12" Foreground="#92400E" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">💡 For Third-Party SharePoint:</Run>
                                <Run> Leave Client Secret empty and use "Interactive Login" button. This opens a browser where you sign in with your Microsoft account that has guest access to the third-party SharePoint.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                        <Button x:Name="btnSaveConfig" 
                                Content="💾 Save Config" 
                                Style="{StaticResource ModernButton}"
                                Click="BtnSaveConfig_Click"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnAuthenticate" 
                                Content="🔑 Client Credentials (Own Tenant)" 
                                Style="{StaticResource SuccessButton}"
                                Click="BtnAuthenticate_Click"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnInteractiveLogin" 
                                Content="🌐 Interactive Login (Third-Party)" 
                                Style="{StaticResource WarningButton}"
                                Click="BtnInteractiveLogin_Click"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnSignOut" 
                                Content="Sign Out" 
                                Style="{StaticResource DangerButton}"
                                Click="BtnSignOut_Click"
                                IsEnabled="False"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnTestConnection" 
                                Content="🔍 Test Connection" 
                                Style="{StaticResource ModernButton}"
                                Click="BtnTestConnection_Click"
                                IsEnabled="False"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnListSites" 
                                Content="📋 List Sites" 
                                Style="{StaticResource ModernButton}"
                                Click="BtnListSites_Click"
                                IsEnabled="False"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="txtAuthStatus" 
                               Text="Not authenticated" 
                               FontSize="13" 
                               Foreground="#DC2626"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- SharePoint URL Section -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📁 Step 2: SharePoint Folder" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                    <TextBlock Text="Paste the SharePoint shared folder URL here (right-click on folder → Copy link)" 
                               FontSize="13" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    
                    <TextBox x:Name="txtSharePointUrl" 
                             Height="40"
                             Padding="12,10"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Margin="0,0,0,12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnDownloadFromUrl" 
                                Content="📥 Download from URL" 
                                Style="{StaticResource ModernButton}"
                                Click="BtnDownloadFromUrl_Click"
                                IsEnabled="False"
                                Margin="0,0,12,0"/>
                        <Button x:Name="btnBrowseSites" 
                                Content="🔍 Browse Sites" 
                                Style="{StaticResource WarningButton}"
                                Click="BtnBrowseSites_Click"
                                IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sites/Drives List -->
            <Border x:Name="borderSitesList" Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📂 Available Sites &amp; Document Libraries" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sites:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox x:Name="lstSites" 
                                     Height="150" 
                                     SelectionChanged="LstSites_SelectionChanged"
                                     DisplayMemberPath="Name"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Document Libraries:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ListBox x:Name="lstDrives" 
                                     Height="150"
                                     SelectionChanged="LstDrives_SelectionChanged"
                                     DisplayMemberPath="Name"/>
                        </StackPanel>
                    </Grid>
                    
                    <Button x:Name="btnDownloadFromDrive" 
                            Content="📥 Download Selected Library" 
                            Style="{StaticResource SuccessButton}"
                            Click="BtnDownloadFromDrive_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- Case Selection Section -->
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📋 Step 3: Database &amp; S3 Configuration" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="Connection String:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtConnectionString" 
                             Height="36"
                             Padding="10,8"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             Text="Server=;Port=3306;Database=;Uid=;Pwd=;"
                             Margin="0,0,0,12">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="S3 Bucket Name:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtBucketName" 
                                     Height="36"
                                     Padding="10,8"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"
                                     Text="laitlegal-documents">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AWS Profile Path:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtProfilePath" 
                                     Height="36"
                                     Padding="10,8"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"
                                     Text="C:\AWS_Profile\LAITLegal.txt">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock Text="Case ID:" FontSize="12" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="txtCaseId" 
                                 Grid.Column="0"
                                 Height="40"
                                 Padding="12,10"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        
                        <Button x:Name="btnImportToCase" 
                                Grid.Column="2"
                                Content="🚀 Import Downloaded Files to Case" 
                                Style="{StaticResource SuccessButton}"
                                Click="BtnImportToCase_Click"
                                IsEnabled="False"/>
                    </Grid>
                    
                    <TextBlock x:Name="txtDownloadPath" 
                               FontSize="12" 
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Log Section -->
            <Border Background="White" CornerRadius="12" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📋 Activity Log" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937"/>
                        <Button x:Name="btnClearLog" 
                                Grid.Column="1"
                                Content="Clear" 
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnClearLog_Click"/>
                    </Grid>
                    <Border Background="#F9FAFB" CornerRadius="8" Padding="16">
                        <ScrollViewer x:Name="scrollLog" Height="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="txtLog" 
                                       FontFamily="Consolas" 
                                       FontSize="12" 
                                       Foreground="#374151"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
