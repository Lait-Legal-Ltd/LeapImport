<Page x:Class="LeapMergeDoc.Pages.BatchFilesImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Batch Files Import"
      Background="#F5F5F5">
    
    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D97706"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📦 Batch Files Import" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#1F2937"/>
            <TextBlock Text="Import files from multiple case folders at once. Folder names like 'AE.74.23' or 'AE.225.25 ALNASSAR' will be matched to cases." 
                       FontSize="14" Foreground="#6B7280" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>
        
        <!-- Configuration Section -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Database Connection -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="DB Connection:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox x:Name="txtConnectionString" Grid.Column="1" 
                             Text="Server=localhost;Port=3306;Database=bais-live;Uid=root;Pwd=;"
                             Height="36" Padding="8,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>
                    <Button Grid.Column="2" Content="Test" Margin="10,0,0,0" Padding="15,8"
                            Click="BtnTestConnection_Click"/>
                </Grid>
                
                <!-- S3 Config -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="S3 Bucket:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox x:Name="txtBucketName" Grid.Column="1" 
                             Text="laitlegal-documents"
                             Height="36" Padding="8,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>
                    <TextBlock Grid.Column="2" Text="AWS Profile Path:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151" Margin="20,0,0,0"/>
                    <TextBox x:Name="txtProfilePath" Grid.Column="3" 
                             Text="C:\AWS_Profile\LAITLegal.txt"
                             Height="36" Padding="8,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>
                </Grid>
                
                <!-- Root Folder Selection -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Root Folder:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151"/>
                    <TextBox x:Name="txtRootFolder" Grid.Column="1" 
                             Text="Select folder containing case subfolders..."
                             Height="36" Padding="8,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1" IsReadOnly="True"
                             Foreground="#6B7280"/>
                    <Button Grid.Column="2" Content="📁 Browse" Margin="10,0,0,0" Padding="15,8"
                            Style="{StaticResource ModernButton}"
                            Click="BtnBrowseFolder_Click"/>
                    <Button x:Name="btnScanFolder" Grid.Column="3" Content="🔍 Scan &amp; Lookup" Margin="10,0,0,0" Padding="15,8"
                            Style="{StaticResource WarningButton}"
                            Click="BtnScanFolder_Click"
                            IsEnabled="False"/>
                </Grid>
                
                <!-- Move on Success -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="After Upload:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151"/>
                    <CheckBox x:Name="chkMoveOnSuccess" Grid.Column="1" 
                              Content="Move successful folders to:" 
                              VerticalAlignment="Center" 
                              IsChecked="True"
                              Margin="0,0,10,0"/>
                    <TextBox x:Name="txtCompletedFolder" Grid.Column="2" 
                             Text=""
                             Height="36" Padding="8,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1" IsReadOnly="True"
                             Foreground="#6B7280"/>
                    <Button Grid.Column="3" Content="📁 Browse" Margin="10,0,0,0" Padding="15,8"
                            Click="BtnBrowseCompletedFolder_Click"/>
                </Grid>
            </Grid>
        </Border>
        
        <!-- Summary -->
        <Border Grid.Row="2" Background="#EEF2FF" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="txtSummary" Text="Select a root folder to scan for case folders" 
                           FontSize="14" Foreground="#4338CA" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnSelectAll" Content="☑ Select All" Padding="15,8"
                    Click="BtnSelectAll_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnSelectNone" Content="☐ Select None" Padding="15,8"
                    Click="BtnSelectNone_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnSelectFound" Content="✓ Select Found Only" Padding="15,8"
                    Click="BtnSelectFound_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnImport" Content="☁️ Import Selected" Padding="20,10"
                    Style="{StaticResource SuccessButton}"
                Click="BtnImport_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnDownloadReport" Content="⬇ Download Missing Report" Padding="15,8"
                Click="BtnDownloadReport_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="btnDownloadAllFiles" Content="⬇ Download All Files ZIP" Padding="15,8"
                Click="BtnDownloadAllFiles_Click" IsEnabled="False"/>
        </StackPanel>
        
        <!-- Case Folders DataGrid -->
        <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <DataGrid x:Name="dgCaseFolders" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E5E7EB"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="White"
                      AlternatingRowBackground="#F9FAFB">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    <DataGridTextColumn Header="Folder Name" Binding="{Binding FolderName}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Case Ref" Binding="{Binding ParsedCaseReference}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Case ID" Binding="{Binding CaseId}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Case Name" Binding="{Binding CaseName}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        
        <!-- Activity Log -->
        <Border Grid.Row="5" Background="White" CornerRadius="12" Padding="16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="📋 Activity Log" FontWeight="SemiBold" FontSize="14" Foreground="#374151"/>
                    <Button Content="Clear" Margin="20,0,0,0" Padding="10,4" FontSize="11"
                            Click="BtnClearLog_Click"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtLog" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#374151"
                             Background="Transparent"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
