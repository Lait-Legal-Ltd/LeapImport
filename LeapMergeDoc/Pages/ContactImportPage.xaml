<Page x:Class="LeapMergeDoc.Pages.ContactImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Contact Import">
    <Page.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Background="#1e1e1e">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock Text="📇 Contact Import" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                
                <!-- Database Connection -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Database Connection" FontWeight="SemiBold" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtConnectionString" 
                                     Text="Server=localhost;Database=customerdbv1;Uid=root;Pwd=;" 
                                     Background="#3d3d3d" Foreground="White" BorderThickness="0" Padding="12" FontSize="12"/>
                            <Button Grid.Column="1" Content="🔗 Test Connection" Click="TestConnection_Click" 
                                    Style="{StaticResource ModernButton}" Background="#2196F3" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- File Selection -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Contact Excel File" FontWeight="SemiBold" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtContactFilePath" Background="#3d3d3d" Foreground="White" 
                                     BorderThickness="0" Padding="12" FontSize="12" IsReadOnly="True"
                                     Text="Select contacts Excel file..."/>
                            <Button Grid.Column="1" Content="📂 Browse" Click="BrowseContactFile_Click" 
                                    Style="{StaticResource ModernButton}" Background="#9C27B0" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <WrapPanel>
                        <Button x:Name="btnPreview" Content="👁️ Preview Data" Click="PreviewData_Click" 
                                Style="{StaticResource ModernButton}" Background="#FF9800" Margin="0,0,10,0" IsEnabled="False"/>
                        <Button x:Name="btnImport" Content="⬆️ Import Contacts" Click="ImportData_Click" 
                                Style="{StaticResource ModernButton}" Background="#4CAF50" Margin="0,0,10,0" IsEnabled="False"/>
                        <Button x:Name="btnTruncate" Content="🗑️ Truncate Contact Data" Click="TruncateData_Click" 
                                Style="{StaticResource ModernButton}" Background="#f44336"/>
                    </WrapPanel>
                </Border>

                <!-- Status Log -->
                <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Status Log" FontWeight="SemiBold" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
                        <TextBox x:Name="txtStatus" Background="#1a1a1a" Foreground="#00ff00" 
                                 BorderThickness="0" Padding="15" FontSize="12" FontFamily="Consolas"
                                 Height="350" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True" AcceptsReturn="True"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
